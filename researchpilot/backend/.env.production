# Production environment configuration for backend
# Copy this to backend/.env when deploying to production

# ── LLM Providers ──────────────────────────────────────────────────────────────
# These should be set as environment variables in your deployment platform
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
TAVILY_API_KEY=your_tavily_api_key

# ── Model Selection ───────────────────────────────────────────────────────────
PRIMARY_MODEL=llama-3.3-70b-versatile
FAST_MODEL=mixtral-8x7b-32768
CRITIC_MODEL=llama-3.3-70b-versatile

# ── A/B Comparison Models ──────────────────────────────────────────────────────
AB_MODEL_1=meta-llama/llama-3.1-8b-instruct:free
AB_MODEL_2=google/gemma-2-9b-it:free
AB_MODEL_3=mistralai/mistral-7b-instruct:free

# ── Embeddings (local) ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage (Production) ───────────────────────────────────────────────────────
# Use cloud storage instead of local filesystem
# Option 1: AWS S3
# CHROMA_PERSIST_DIR=s3://your-bucket/chroma
# UPLOAD_DIR=s3://your-bucket/uploads

# Option 2: Google Cloud Storage
# CHROMA_PERSIST_DIR=gs://your-bucket/chroma
# UPLOAD_DIR=gs://your-bucket/uploads

# Option 3: Azure Blob Storage
# CHROMA_PERSIST_DIR=https://your-account.blob.core.windows.net/chroma
# UPLOAD_DIR=https://your-account.blob.core.windows.net/uploads

# Option 4: Keep local if using persistent volumes
CHROMA_PERSIST_DIR=/var/data/chroma
UPLOAD_DIR=/var/data/uploads

# ── Database (Production) ──────────────────────────────────────────────────────
# Option 1: PostgreSQL (recommended)
DATABASE_URL=postgresql://user:password@host:5432/researchpilot

# Option 2: MySQL
# DATABASE_URL=mysql://user:password@host:3306/researchpilot

# Option 3: SQLite (not recommended for production)
# DATABASE_URL=sqlite:///./data/researchpilot.db

# ── Pipeline Config ───────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_AGENTS=4
CONFIDENCE_THRESHOLD=0.6
CRITIC_THRESHOLD=0.65

# ── CORS (Update with your frontend domain) ────────────────────────────────────
CORS_ORIGINS=https://your-site.netlify.app,http://localhost:5173

# ── Port ────────────────────────────────────────────────────────────────────
# Usually set by the hosting platform, but you can override
PORT=8000
