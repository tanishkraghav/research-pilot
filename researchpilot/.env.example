# ── LLM Providers (all free tiers) ──────────────────────────────────────────
# Groq: https://console.groq.com  (free, ultra-fast inference)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter: https://openrouter.ai (free tier models available)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Tavily: https://tavily.com (1000 free searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# ── Model Selection ───────────────────────────────────────────────────────────
# Primary research model (Groq - free)
PRIMARY_MODEL=llama-3.1-70b-versatile
# Fast model for specialist agents (Groq - free)
FAST_MODEL=llama-3.1-8b-instant
# Critic/eval model (Groq - free)
CRITIC_MODEL=llama-3.3-70b-versatile

# ── A/B Comparison Models via OpenRouter (free tier) ─────────────────────────
AB_MODEL_1=meta-llama/llama-3.1-8b-instruct:free
AB_MODEL_2=google/gemma-2-9b-it:free
AB_MODEL_3=mistralai/mistral-7b-instruct:free

# ── Embeddings (local, 100% free) ────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
DATABASE_URL=sqlite:///./data/researchpilot.db

# ── Pipeline Config ───────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_AGENTS=4
CONFIDENCE_THRESHOLD=0.6
CRITIC_THRESHOLD=0.65

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
